PORT=3000

# Vapi Keys (Public key for frontend widget, Private key for server-side API calls)
VAPI_API_PUBLIC_KEY=your_vapi_public_key
VAPI_API_PRIVATE_KEY=your_vapi_private_key

# Assistant IDs (one per service/page)
VAPI_ASSISTANT_ID_CUSHLABS=your_cushlabs_assistant_id
VAPI_ASSISTANT_ID_COACHING=your_coaching_assistant_id

# LLM Provider
GROQ_API_KEY=your_groq_api_key

# Voice Provider
CARTESIA_API_KEY=your_cartesia_api_key

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Redis connection string
REDIS_URL=redis://localhost:6379

# Coach email for calendar invites
COACH_EMAIL=your_email@example.com
