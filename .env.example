PORT=3000

# Vapi Keys (Public key for frontend widget, Private key for server-side API calls)
VAPI_API_PUBLIC_KEY=your_vapi_public_key
VAPI_API_PRIVATE_KEY=your_vapi_private_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id

# LLM Provider
GROQ_API_KEY=your_groq_api_key

# Voice Provider
CARTESIA_API_KEY=your_cartesia_api_key

# Redis connection string (local default or managed instance URL)
REDIS_URL=redis://localhost:6379
